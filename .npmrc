# Supply-chain protection (pnpm 10+/11+)

# Delay use of newly published packages (in minutes). 1440 = 1 day.
# Mitigates fast-moving compromise windows of npm packages.
minimumReleaseAge=1440

# Enforce packageManager field — refuse to run with the wrong package manager / version.
package-manager-strict=true
package-manager-strict-version=true

# Detect out-of-sync lockfile / node_modules before running scripts.
verify-deps-before-run=error

# Verify the integrity of the content-addressable store on every install.
verify-store-integrity=true

# Make `pnpm audit` report at least moderate vulnerabilities.
audit-level=moderate

# Quality of life
auto-install-peers=true
update-notifier=false
