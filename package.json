{
  "name": "astro-iubenda",
  "description": "Astro integration for Iubenda Privacy Policy and Terms & Conditions",
  "repository": "https://github.com/Valyay/astro-iubenda",
  "homepage": "https://github.com/Valyay/astro-iubenda#readme",
  "bugs": {
    "url": "https://github.com/Valyay/astro-iubenda/issues"
  },
  "keywords": [
    "astro",
    "withastro",
    "astro-integration",
    "iubenda",
    "privacy-policy",
    "terms-and-conditions",
    "consent",
    "cookie-banner",
    "cookie-policy",
    "cookie-consent-banner",
    "consent-management",
    "cmp",
    "gdpr",
    "lgpd",
    "ccpa"
  ],
  "author": "Evgeniy Valyaev <dev.valyay@gmail.com>",
  "license": "MIT",
  "type": "module",
  "version": "0.4.2",
  "main": "./dist/index.js",
  "exports": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "virtual.d.ts"
  ],
  "scripts": {
    "clean": "rimraf dist pnpm-lock.yaml .pnpm-debug.log node_modules",
    "typecheck": "tsc --noEmit --pretty",
    "test:pub": "pnpm publish --dry-run --no-git-checks",
    "preinstall": "npx only-allow pnpm",
    "build": "tsup",
    "lint": "eslint . --ext .ts,.js,.mjs,.cjs",
    "lint:fix": "eslint . --fix --ext .ts,.js,.mjs,.cjs",
    "format": "prettier -w  .",
    "prettier:check": "prettier --check .",
    "prepack": "pnpm run build && cp ./virtual.d.ts dist/virtual.d.ts",
    "changeset": "changeset",
    "version": "changeset version && pnpm install --no-frozen-lockfile",
    "release": "pnpm run build && changeset publish",
    "test": "vitest run",
    "test:watch": "vitest",
    "size": "size-limit"
  },
  "peerDependencies": {
    "astro": "^2.0.0 || ^3.0.0 || ^4.0.0 || ^5.0.0"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.8",
    "@size-limit/preset-small-lib": "^12.0.0",
    "@types/node": "^25.0.3",
    "@typescript-eslint/eslint-plugin": "^8.50.0",
    "@typescript-eslint/parser": "^8.50.0",
    "@vitest/coverage-v8": "^4.0.16",
    "astro": "^5.16.6",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "nano-staged": "^0.9.0",
    "prettier": "^3.7.4",
    "rimraf": "^6.1.2",
    "simple-git-hooks": "^2.13.1",
    "size-limit": "^12.0.0",
    "size-limit-preset-node-lib": "^0.4.0",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.50.0",
    "vite": "^7.3.0",
    "vitest": "^4.0.16"
  },
  "size-limit": [
    {
      "path": "dist/index.js",
      "limit": "2.314 kB"
    }
  ],
  "nano-staged": {
    "*.{js,jsx,ts,tsx,astro}": [
      "prettier --write",
      "eslint --fix"
    ]
  },
  "simple-git-hooks": {
    "pre-commit": "./node_modules/.bin/nano-staged",
    "postinstall": "npx simple-git-hooks"
  },
  "engines": {
    "pnpm": ">=10",
    "node": ">=20"
  }
}
